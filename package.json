{
  "name": "obscura",
  "version": "1.0.0",
  "private": true,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/edycutjong/obscura.git"
  },
  "bugs": {
    "url": "https://github.com/edycutjong/obscura/issues"
  },
  "homepage": "https://obscura.edycu.dev",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "typecheck": "tsc --noEmit",
    "format:check": "prettier --check .",
    "format:write": "prettier --write .",
    "test": "npx tsx scripts/test.js",
    "test:coverage": "npx nyc npx ts-node -O '{\"module\": \"commonjs\", \"moduleResolution\": \"node\"}' scripts/test.js",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "audit": "npm audit --audit-level=high",
    "ci": "(npm run audit || true) && npm run lint && npm run typecheck && npm run test:coverage",
    "ci:full": "npm run ci && npm run build && npm run e2e",
    "lighthouse": "lhci autorun",
    "prove:demo": "node scripts/prove-and-verify.mjs",
    "prove:demo:netting": "node scripts/prove-and-verify-netting.mjs",
    "prove:demo:multinet": "node scripts/prove-and-verify-multinet.mjs"
  },
  "dependencies": {
    "@stellar/stellar-sdk": "^16.0.0",
    "@supabase/supabase-js": "^2.108.2",
    "dotenv": "^17.4.2",
    "next": "16.2.9",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^10",
    "eslint-config-next": "16.2.9",
    "tailwindcss": "^4",
    "typescript": "^5",
    "prettier": "^3.0.0",
    "tsx": "^4.22.4",
    "ts-node": "^10.9.2",
    "@lhci/cli": "^0.14.0"
  },
  "nyc": {
    "all": true,
    "include": [
      "src/lib/**/*.ts"
    ],
    "exclude": [
      "src/lib/confetti.ts"
    ],
    "extension": [
      ".ts",
      ".tsx"
    ],
    "reporter": [
      "text",
      "html"
    ]
  }
}
